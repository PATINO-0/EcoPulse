# ============================================================
# EcoPulse environment variables
# ============================================================

# Supabase
# Usa solo la URL base del proyecto.
# Correcto:
# https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Incorrecto:
# https://xxxxxxxxxxxxxxxxxxxx.supabase.co/rest/v1
# https://xxxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1
SUPABASE_URL=

# Puede ser la anon key antigua o la nueva publishable key tipo sb_publishable_xxx.
SUPABASE_ANON_KEY=

# Groq API
GROQ_API_KEY=

# Map provider
# No es obligatorio para flutter_map con OpenStreetMap.
# Se deja preparado para proveedores futuros como MapTiler, Stadia, Mapbox, etc.
MAPS_API_KEY=

# Valores por defecto
DEFAULT_CITY=PASTO
DEFAULT_DEPARTMENT=NARIÑO
DEFAULT_COUNTRY=COLOMBIA

# Política de datos personales
PRIVACY_POLICY_VERSION=1.0.0